{
  "name": "danielshort-website",
  "version": "1.0.0",
  "private": true,
  "description": "Simple tests for Daniel Short's website",
  "scripts": {
    "test": "node test.js && node tests/project-starfall-bundle.test.js && node tests/project-starfall-visual-viewport.test.js && node tests/project-starfall-enemy-fx-uniqueness.test.js && node tests/aws-credentials.test.js && node tests/aws-data-migrations.test.js && node tests/chatbot-stream-proxy.test.js && node tests/tools-auth-session.test.js && node build/validate-seo.js",
    "test:chatbot-stream": "node tests/chatbot-stream-proxy.test.js",
    "test:aws-credentials": "node tests/aws-credentials.test.js",
    "test:seo": "node build/validate-seo.js",
    "test:aws-migrations": "node tests/aws-data-migrations.test.js",
    "test:starfall": "npm run test:starfall:smoke && npm run test:starfall:systems && npm run test:starfall:combat && npm run test:starfall:progression && npm run test:starfall:inventory && npm run test:starfall:balance",
    "test:starfall:smoke": "node test.js --suite=starfall-smoke",
    "test:starfall:inventory": "node test.js --suite=starfall-inventory",
    "test:starfall:systems": "node test.js --suite=starfall-systems",
    "test:starfall:combat": "node test.js --suite=starfall-combat",
    "test:starfall:balance": "node test.js --suite=starfall-balance",
    "test:starfall:progression": "node test.js --suite=starfall-progression",
    "test:starfall:assets": "node test.js --suite=starfall-assets",
    "test:starfall:enemy-fx": "node tests/project-starfall-enemy-fx-uniqueness.test.js",
    "test:starfall:bundle": "node tests/project-starfall-bundle.test.js && node tests/project-starfall-visual-viewport.test.js && node tests/project-starfall-enemy-fx-uniqueness.test.js",
    "test:starfall:full": "npm run test:starfall && npm run test:starfall:assets && npm run test:starfall:bundle",
    "test:all": "node test.js --suite=all",
    "build:icons": "node build/resize_logo.js",
    "build:css": "node build/build-css.js",
    "build:images": "node build/optimize-site-images.js",
    "build:js": "node build/build-js.js",
    "build:utm-batch-builder": "node build/build-utm-batch-builder.js",
    "build:pizza-tips-model": "node build/build-pizza-tips-model.js",
    "build:stellar-dogfight-assets": "node build/build-stellar-dogfight-assets.js",
    "build:models": "npm run build:pizza-tips-model",
    "build:projects": "node build/generate-project-pages.js",
    "build:cms-content": "node build/generate-cms-artifacts.js",
    "build:shortlinks-destinations": "node build/generate-shortlinks-destinations.js",
    "build:project-starfall-assets": "node build/process-project-starfall-non-enemy-ai-assets.js",
    "build:project-starfall-card-icons": "node build/process-project-starfall-card-icons.js",
    "build:project-starfall-equipment-atlases": "node build/generate-project-starfall-equipment-atlases.js --all",
    "build:project-starfall-item-visual-assets": "node build/generate-project-starfall-item-visual-assets.js",
    "validate:project-starfall-assets": "node build/validate-project-starfall-asset-generation.js",
    "validate:project-starfall-equipment-atlases": "node build/generate-project-starfall-equipment-atlases.js --all --validate",
    "validate:project-starfall-class-skills": "node build/validate-project-starfall-class-skills.js",
    "validate:project-starfall-item-visuals": "node build/validate-project-starfall-item-visuals.js",
    "validate:starfall:maps": "node build/validate-project-starfall-maps.js",
    "analyze:starfall:balance": "node build/analyze-project-starfall-balance.js",
    "record:project-previews": "node build/record-project-previews.js",
    "migrate:content": "node build/migrate-content.js",
    "migrate:short-links-clicks": "node scripts/migrations/short-links-clicks-reconcile.js",
    "migrate:short-links-reservations": "node scripts/migrations/short-links-reservations.js",
    "migrate:tools-ttl": "node scripts/migrations/tools-ttl-backfill.js",
    "scaffold": "node build/scaffold.js",
    "build": "node build/build-site.js",
    "dev": "node build/dev.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1085.0",
    "@aws-sdk/client-dynamodb": "^3.1085.0",
    "@aws-sdk/client-lambda": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/client-transcribe": "^3.1085.0",
    "@aws-sdk/lib-dynamodb": "^3.1085.0",
    "@aws-sdk/s3-presigned-post": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@vercel/oidc-aws-credentials-provider": "^3.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sharp": "^0.34.5"
  }
}
