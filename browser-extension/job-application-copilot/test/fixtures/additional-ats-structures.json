{
  "cases": [
    {
      "id": "icims",
      "source": "iCIMS",
      "url": "https://careers.icims.com/jobs/100/application",
      "selector": "[data-icims-application]",
      "root": {
        "selector": "[data-icims-application]",
        "tagName": "FORM",
        "id": "icims-application-form",
        "className": "icims candidate application",
        "fields": [
          {
            "tagName": "INPUT",
            "type": "text",
            "name": "candidateFirstName",
            "label": "First name"
          },
          {
            "tagName": "INPUT",
            "type": "text",
            "name": "candidateLastName",
            "label": "Last name"
          },
          {
            "tagName": "INPUT",
            "type": "email",
            "name": "candidateEmail",
            "label": "Email address"
          },
          {
            "tagName": "TEXTAREA",
            "type": "textarea",
            "name": "interest",
            "label": "Why are you interested in this role?"
          },
          {
            "tagName": "INPUT",
            "type": "file",
            "name": "resume",
            "label": "Resume"
          },
          {
            "tagName": "BUTTON",
            "type": "submit",
            "name": "submit",
            "label": "Submit application"
          }
        ]
      }
    },
