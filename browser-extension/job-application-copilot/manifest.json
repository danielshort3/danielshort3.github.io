{
  "manifest_version": 3,
  "name": "Job Application Copilot",
  "description": "Prepare grounded job-application answers with a local Ollama model and explicit review.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "homepage_url": "https://www.danielshort.me/job-application-copilot",
  "key": "",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://127.0.0.1:11434/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Job Application Copilot",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.danielshort.me/tools/job-application-tracker*"
      ],
      "js": [
        "content/tracker-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; base-uri 'none'; object-src 'none'; frame-src 'none'; script-src 'self'; style-src 'self'; worker-src 'self'; connect-src http://127.0.0.1:11434"
  }
}
