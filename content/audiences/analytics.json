      {
        "id": "audience-analytics-5",
        "type": "legacy-html",
        "label": "Project Examples",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"project-examples\" class=\"project-examples-band surface-band no-reveal\" role=\"region\" aria-labelledby=\"project-examples-title\">\n      <div class=\"wrapper\">\n        <div class=\"project-examples-head\">\n          <h2 id=\"project-examples-title\">Project Examples</h2>\n          <p class=\"project-examples-subtitle\">A quick look at dashboarding, SQL workflows, and decision support tied to business questions.</p>\n        </div>\n\n        <div class=\"project-examples-grid\" role=\"list\" aria-label=\"Project Examples\">\n          <a\n            class=\"project-card ripple-in project-examples-card\"\n            role=\"listitem\"\n            href=\"portfolio/retailStore\"\n            aria-label=\"View Store-Level Loss and Sales ETL case study\">\n            <div class=\"overlay\"></div>\n            <div class=\"project-text\">\n              <div class=\"project-title\">Store-Level Loss &amp; Sales ETL</div>\n              <div class=\"project-subtitle\">SQL ETL and Anomaly Detection</div>\n            </div>\n            <video class=\"gif-video\" muted playsinline loop preload=\"none\" aria-label=\"Store-level loss and sales preview\" draggable=\"false\" poster=\"img/projects/retailStore.png\">\n              <source data-src=\"img/projects/retailStore.webm\" type=\"video/webm\">\n              <source data-src=\"img/projects/retailStore.mp4\" type=\"video/mp4\">\n            </video>\n            <picture>\n              <source srcset=\"img/projects/retailStore-640.avif 640w, img/projects/retailStore-960.avif 960w, img/projects/retailStore.avif 1410w\" type=\"image/avif\">\n              <source srcset=\"img/projects/retailStore-640.webp 640w, img/projects/retailStore-960.webp 960w, img/projects/retailStore.webp 1410w\" type=\"image/webp\">\n              <img src=\"img/projects/retailStore.png\" alt=\"Preview of store-level loss and sales analysis dashboard\" width=\"1410\" height=\"1410\" loading=\"lazy\" decoding=\"async\" draggable=\"false\" sizes=\"(max-width: 640px) 92vw, 340px\">\n            </picture>\n          </a>\n\n          <a\n            class=\"project-card ripple-in project-examples-card\"\n            role=\"listitem\"\n            href=\"portfolio/targetEmptyPackage\"\n            aria-label=\"View Empty-Package Shrink Dashboard case study\">\n            <div class=\"overlay\"></div>\n            <div class=\"project-text\">\n              <div class=\"project-title\">Empty-Package Shrink Dashboard</div>\n              <div class=\"project-subtitle\">Excel Forecasting and BI</div>\n            </div>\n            <video class=\"gif-video\" muted playsinline loop preload=\"none\" aria-label=\"Empty-package shrink dashboard preview\" draggable=\"false\" poster=\"img/projects/targetEmptyPackage.png\">\n              <source data-src=\"img/projects/targetEmptyPackage.webm\" type=\"video/webm\">\n              <source data-src=\"img/projects/targetEmptyPackage.mp4\" type=\"video/mp4\">\n            </video>\n            <picture>\n              <source srcset=\"img/projects/targetEmptyPackage-640.avif 640w, img/projects/targetEmptyPackage-960.avif 960w, img/projects/targetEmptyPackage.avif 1460w\" type=\"image/avif\">\n              <source srcset=\"img/projects/targetEmptyPackage-640.webp 640w, img/projects/targetEmptyPackage-960.webp 960w, img/projects/targetEmptyPackage.webp 1460w\" type=\"image/webp\">\n              <img src=\"img/projects/targetEmptyPackage.png\" alt=\"Preview of empty-package shrink dashboard\" width=\"1460\" height=\"1460\" loading=\"lazy\" decoding=\"async\" draggable=\"false\" sizes=\"(max-width: 640px) 92vw, 340px\">\n            </picture>\n          </a>\n\n          <a\n            class=\"project-card ripple-in project-examples-card\"\n            role=\"listitem\"\n            href=\"portfolio/pizzaDashboard\"\n            aria-label=\"View Pizza Delivery Dashboard case study\">\n            <div class=\"overlay\"></div>\n            <div class=\"project-text\">\n              <div class=\"project-title\">Pizza Delivery Dashboard</div>\n              <div class=\"project-subtitle\">Tableau Analytics and Forecasting</div>\n            </div>\n            <picture>\n              <source srcset=\"img/projects/pizzaDashboard-640.avif 640w, img/projects/pizzaDashboard-960.avif 960w, img/projects/pizzaDashboard.avif 1250w\" type=\"image/avif\">\n              <source srcset=\"img/projects/pizzaDashboard-640.webp 640w, img/projects/pizzaDashboard-960.webp 960w, img/projects/pizzaDashboard.webp 1250w\" type=\"image/webp\">\n              <img src=\"img/projects/pizzaDashboard.png\" alt=\"Preview of the Pizza Delivery Tableau dashboard\" width=\"1250\" height=\"1092\" loading=\"lazy\" decoding=\"async\" draggable=\"false\" sizes=\"(max-width: 640px) 92vw, 340px\">\n            </picture>\n          </a>\n        </div>\n\n        <div class=\"project-examples-actions\">\n          <a href=\"portfolio?audience=analytics\" class=\"btn-secondary project-examples-cta\">View portfolio</a>\n        </div>\n      </div>\n    </section>"
        }
