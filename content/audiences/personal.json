      {
        "id": "home-tools",
        "type": "legacy-html",
        "label": "Tools",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"tools-preview\" class=\"surface-band reveal destination-section\" aria-labelledby=\"tools-preview-title\"><div class=\"wrapper\"><div class=\"destination-section-head\"><h2 id=\"tools-preview-title\">Tools</h2><p>Small utilities built for repeated, practical use: writing cleanup, media processing, link building, and quick analysis.</p></div><div class=\"who-i-work-with-grid\"><article class=\"who-i-work-with-card\"><h3>Writing &amp; Text</h3><p>Text Compare, Word Frequency, Oxford Comma Checker, Point of View Checker, and whitespace cleanup.</p><a class=\"btn-secondary\" href=\"tools\">Open tools</a></article><article class=\"who-i-work-with-card\"><h3>Images &amp; Media</h3><p>Image optimization, background removal, QR codes, screen recording, and transcription helpers.</p><a class=\"btn-secondary\" href=\"tools\">Browse utilities</a></article><article class=\"who-i-work-with-card\"><h3>Marketing &amp; Links</h3><p>UTM batch building, short links, and campaign helpers for cleaner repeatable workflows.</p><a class=\"btn-secondary\" href=\"tools/utm-batch-builder\">Try UTM builder</a></article></div></div></section>"
        }
      },
      {
        "id": "home-experiments",
        "type": "legacy-html",
        "label": "Experiments",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"experiments\" class=\"surface-band reveal destination-section\" aria-labelledby=\"experiments-title\"><div class=\"wrapper\"><div class=\"destination-section-head\"><h2 id=\"experiments-title\">Experiments</h2><p>Interactive work that is more playful or exploratory than polished case study: games, simulations, prototypes, and interface sketches.</p></div><div class=\"who-i-work-with-grid\"><article class=\"who-i-work-with-card\"><h3>Games</h3><p>Small browser games and probability experiments built around interaction, state, and feedback.</p><a class=\"btn-secondary\" href=\"games\">Open games</a></article><article class=\"who-i-work-with-card\"><h3>Ocean Wave Simulation</h3><p>A visual simulation focused on motion, controls, and lightweight browser rendering.</p><a class=\"btn-secondary\" href=\"games/ocean-wave-simulation\">View simulation</a></article><article class=\"who-i-work-with-card\"><h3>Website Work</h3><p>Notes and implementation examples from building and refining this site itself.</p><a class=\"btn-secondary\" href=\"portfolio/website\">View website project</a></article></div></div></section>"
