---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About | Daniel Short</title>
    <meta
      name="description"
      content="About Daniel Short, a data scientist focused on business-impactful NLP, CV, and ETL systems."
    />
  </head>
  <body class="font-sans text-deep-text antialiased">
    <main class="mx-auto flex min-h-screen w-full max-w-4xl flex-col justify-center px-4 py-10">
      <a href="/" class="mb-8 text-sm text-cyan-300 transition hover:text-cyan-200">← Back to home</a>
      <section class="bento-card">
        <p class="text-xs uppercase tracking-[0.16em] text-cyan-300">About</p>
        <h1 class="mt-4 text-3xl font-bold text-slate-100">Daniel Short</h1>
        <p class="mt-4 text-base leading-7 text-deep-muted">
          Data scientist specializing in NLP, computer vision, and ETL product systems with a focus
          on measurable outcomes including 500% KPI gains and 200+ annual hours reclaimed through
          automation.
        </p>
      </section>
    </main>
  </body>
</html>
