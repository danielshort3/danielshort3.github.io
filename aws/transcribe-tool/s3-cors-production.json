{
  "CORSRules": [
    {
      "ID": "WebsitePresignedUploads",
      "AllowedHeaders": [
        "content-type",
        "x-amz-date",
        "x-amz-security-token",
        "authorization"
      ],
      "AllowedMethods": [
        "POST",
        "PUT"
      ],
      "AllowedOrigins": [
        "https://www.danielshort.me",
        "https://danielshort.me",
        "https://dshort.me",
        "https://www.dshort.me",
        "http://localhost:*",
        "http://127.0.0.1:*"
      ],
      "ExposeHeaders": [
        "etag",
        "x-amz-request-id"
      ],
      "MaxAgeSeconds": 3000
    }
  ]
}
