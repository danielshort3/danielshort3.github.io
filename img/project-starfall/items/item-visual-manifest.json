      { "theme": "star_magic", "includes": ["upgrade", "catalyst", "warding", "refinement", "cube", "prism", "line_catalyst", "star_card", "plinko", "skill_manual", "reset_scroll", "worldwright"] },
      { "theme": "forest", "includes": ["moss", "thorn", "vine", "bristle", "briar", "bramble", "root", "bark", "antler", "glow_spores", "thorncrown", "thornroot", "briarstring", "rootstep"] },
      { "theme": "construct", "includes": ["clock", "gear", "chrono", "ratchet", "titan", "gyro", "spring", "rustcoil", "coil", "scrap"] },
      { "theme": "cinder", "includes": ["ember", "ash", "molten", "cinder", "furnace", "lava", "scorch", "magma", "ashen", "emberjaw"] },
      { "theme": "frost", "includes": ["rime", "frozen", "glacier", "snow", "icebloom", "frostfen", "frost", "snowstep"] },
      { "theme": "storm", "includes": ["storm", "thunder", "gale", "cloud", "tempest", "lightning", "sky", "roc", "plume", "feather", "fletching"] },
      { "theme": "astral", "includes": ["astral", "star", "comet", "archivist", "archive", "index", "scribe", "orbit", "codex", "runic", "lumen", "starglass", "runewoven", "channeler", "aether"] },
      { "theme": "eclipse", "includes": ["eclipse", "umbral", "corona", "sovereign", "penumbra", "sunfall", "void", "rift"] },
