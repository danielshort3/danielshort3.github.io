---
import BaseLayout from '../layouts/BaseLayout.astro';
import EdgeAIHandwritingDemo from '../components/react/EdgeAIHandwritingDemo.jsx';
import DocumentRestorationSlider from '../components/react/DocumentRestorationSlider.jsx';

const metrics = [
  { label: 'KPI Uplift', value: '500%' },
  { label: 'Automation Saved', value: '200+ hrs/year' },
  { label: 'Traffic Lift', value: '750%' }
];
---

<BaseLayout
  title="Daniel Short | Data Science Made Actionable"
  description="Agentic portfolio for Daniel Short featuring KPI gains, ETL automation, NLP, and computer vision demos."
>
  <main id="main" class="mx-auto max-w-7xl px-4 pb-20 pt-8 sm:px-6 lg:px-8">
    <header class="mb-8 flex flex-wrap items-center justify-between gap-4">
      <a href="/" class="text-lg font-semibold tracking-tight text-cyan-100">danielshort.me</a>
      <nav class="flex flex-wrap items-center gap-3 text-sm text-cyan-100/85">
        <a class="hover:text-cyan-200" href="/about">About</a>
        <a class="hover:text-cyan-200" href="/projects">Projects</a>
        <a class="hover:text-cyan-200" href="/contact.html">Contact</a>
        <a class="accent-button" href="/resume.html">Resume</a>
      </nav>
    </header>

    <section class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-12">
      <article class="surface-card xl:col-span-7">
        <p class="text-xs uppercase tracking-[0.2em] text-cyan-200/80">Agentic Portfolio 2026</p>
        <h1 class="mt-2 text-3xl font-extrabold leading-tight sm:text-4xl">Data Science Made Actionable</h1>
        <p class="mt-4 max-w-2xl text-base text-cyan-50/85">
          500% KPI Gains &amp; Automation. Daniel builds production NLP, computer vision, and ETL systems that move
          business metrics instead of dashboards.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          {metrics.map((metric) => (
            <div class="metric-badge" aria-label={metric.label}>
              <strong class="mr-2 text-cyan-100">{metric.value}</strong>
              <span class="text-cyan-100/80">{metric.label}</span>
            </div>
          ))}
        </div>

        <div class="mt-6 flex flex-wrap gap-3 text-sm">
          <span class="rounded-full border border-cyan-300/30 px-3 py-1">NLP</span>
          <span class="rounded-full border border-cyan-300/30 px-3 py-1">Computer Vision</span>
          <span class="rounded-full border border-cyan-300/30 px-3 py-1">ETL Pipelines</span>
          <span class="rounded-full border border-cyan-300/30 px-3 py-1">Edge AI</span>
        </div>
      </article>

      <article class="surface-card xl:col-span-5">
        <h2 class="text-xl font-semibold text-cyan-50">Current Focus</h2>
        <p class="mt-3 text-sm text-cyan-100/85">
          Transitioning static portfolio pages into a delegative UI system: low-JS Astro islands, client-side model
          inference, and recruiter-optimized machine-readable metadata.
        </p>
        <ul class="mt-4 space-y-2 text-sm text-cyan-100/80">
          <li>Client-side ONNX runtime pathway for demo reliability.</li>
          <li>Bento-grid delivery to compress decision-making time for recruiters.</li>
          <li>Command palette navigation for instant access to resume, projects, and contact.</li>
        </ul>
      </article>

      <article class="surface-card md:col-span-2 xl:col-span-6" id="projects">
        <div class="mb-3 flex items-center justify-between gap-4">
          <h2 class="text-xl font-semibold text-cyan-50">Retail Loss ETL</h2>
          <span class="metric-badge text-cyan-100">24% reduction in loss</span>
        </div>
        <p class="text-sm text-cyan-100/85">
          Built an automated ETL and alerting chain that unified POS exceptions, inventory adjustments, and loss events
          into one operational queue. Outcome: reduced shrink-related loss by 24% with faster response times.
        </p>

        <div class="mt-4 rounded-xl border border-cyan-300/25 bg-slate-950/70 p-4">
          <p class="mb-3 text-xs uppercase tracking-[0.15em] text-cyan-200/70">Interactive pipeline diagram placeholder</p>
          <svg viewBox="0 0 640 140" role="img" aria-label="ETL pipeline placeholder" class="w-full">
            <defs>
              <linearGradient id="pipeGradient" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#004d40"></stop>
                <stop offset="100%" stop-color="#00bcd4"></stop>
              </linearGradient>
            </defs>
            <rect x="20" y="36" width="160" height="68" rx="12" fill="#0f172a" stroke="#22d3ee"></rect>
            <rect x="240" y="36" width="160" height="68" rx="12" fill="#0f172a" stroke="#22d3ee"></rect>
            <rect x="460" y="36" width="160" height="68" rx="12" fill="#0f172a" stroke="#22d3ee"></rect>
            <path d="M 180 70 L 240 70" stroke="url(#pipeGradient)" stroke-width="8" stroke-linecap="round"></path>
            <path d="M 400 70 L 460 70" stroke="url(#pipeGradient)" stroke-width="8" stroke-linecap="round"></path>
            <text x="100" y="78" fill="#e2e8f0" text-anchor="middle" font-size="14">Raw Signals</text>
            <text x="320" y="78" fill="#e2e8f0" text-anchor="middle" font-size="14">ETL Rules</text>
            <text x="540" y="78" fill="#e2e8f0" text-anchor="middle" font-size="14">Ops Actions</text>
          </svg>
        </div>
      </article>

      <div class="md:col-span-2 xl:col-span-6">
        <EdgeAIHandwritingDemo client:visible />
      </div>

      <div class="md:col-span-2 xl:col-span-7">
        <DocumentRestorationSlider client:visible />
      </div>

      <article class="surface-card md:col-span-2 xl:col-span-5">
        <h2 class="text-xl font-semibold text-cyan-50">Project Briefs (STAR-M)</h2>
        <div class="mt-3 space-y-4 text-sm text-cyan-100/85">
          <div>
            <h3 class="font-semibold text-cyan-50">Edge AI Handwriting Recognition</h3>
            <p>
              Re-architected the former shape classifier into a client-side inference demo. Goal: sub-10ms local
              execution for instant character feedback and zero server cold starts.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-cyan-50">Computer Vision Document Restoration</h3>
            <p>
              Reframed sheet-music cleanup as a generative restoration problem: recover legible notation from degraded
              or watermarked scans while preserving staff geometry.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-cyan-50">Narrative Positioning</h3>
            <p>
              Removed generic student framing in favor of impact-first evidence: KPI movement, latency targets, and
              automation savings tied directly to business outcomes.
            </p>
          </div>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
