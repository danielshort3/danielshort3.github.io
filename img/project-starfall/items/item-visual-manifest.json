      { "category": "star_card", "suffixes": ["_star_card"] },
      { "category": "potion", "includes": ["health_potion", "resource_tonic"] },
      { "category": "food", "includes": ["ration"] },
      { "category": "coupon", "includes": ["coupon"] },
      { "category": "upgrade_material", "ids": ["upgrade_dust", "upgrade_catalyst", "warding_scroll", "refinement_core", "cube_fragment", "potential_cube", "preservation_cube", "line_catalyst"] },
      { "category": "scroll", "includes": ["scroll", "manual", "codex", "page", "index"] },
      { "category": "tool", "ids": ["pet_whistle", "guard_tonic", "swiftstep_oil", "magnet_charm", "admin_worldwright_console", "plinko_ball_basic", "plinko_ball_polished", "plinko_ball_meteor"] },
      { "category": "crafting_material", "includes": ["dust", "hide", "fiber", "bead", "claw", "scrap", "coil", "plate", "carapace", "fang", "gland", "cloth", "spores", "crown", "core", "ore", "badge", "shard", "petal", "feather", "fletching", "horn", "silk", "splinter", "sigil", "plume", "corona"] }
