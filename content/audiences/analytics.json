      {
        "id": "audience-analytics-2",
        "type": "legacy-html",
        "label": "Business-Facing Results",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"selected-outcomes\" class=\"home-proof-band surface-band no-reveal\" role=\"region\" aria-labelledby=\"selected-outcomes-title\">\n      <div class=\"wrapper\">\n        <div class=\"home-proof-head\">\n          <h2 id=\"selected-outcomes-title\" class=\"section-title\">Business-Facing Results</h2>\n          <p>A concise snapshot of outcomes behind the featured analytics projects.</p>\n        </div>\n        <ul class=\"home-proof-kpis\" aria-label=\"Business-facing analytics results\">\n          <li class=\"home-proof-item\">\n            <div class=\"home-proof-card\">\n              <span class=\"home-proof-value\">99%</span>\n              <span class=\"home-proof-label\">Faster reporting turnaround on recurring leadership and stakeholder updates.</span>\n            </div>\n          </li>\n          <li class=\"home-proof-item\">\n            <div class=\"home-proof-card\">\n              <span class=\"home-proof-value\">200+</span>\n              <span class=\"home-proof-label\">Hours saved annually by automating recurring report prep and delivery.</span>\n            </div>\n          </li>\n          <li class=\"home-proof-item\">\n            <div class=\"home-proof-card\">\n              <span class=\"home-proof-value\">24%</span>\n              <span class=\"home-proof-label\">Inventory loss reduction through analytics-driven investigations and workflow improvements.</span>\n            </div>\n          </li>\n          <li class=\"home-proof-item\">\n            <div class=\"home-proof-card\">\n              <span class=\"home-proof-value\">57.6%</span>\n              <span class=\"home-proof-label\">Improvement in theft reporting after dashboard and process redesign.</span>\n            </div>\n          </li>\n        </ul>\n      </div>\n    </section>"
        }
      },
      {
        "id": "audience-analytics-6",
        "type": "legacy-html",
        "label": "Certifications &amp; Degrees",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<div id=\"certifications-modal\" class=\"modal\">\n      <div class=\"modal-content\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"cert-modal-title\" tabindex=\"0\">\n        <button class=\"modal-close\" aria-label=\"Close dialog\">&times;</button>\n        <div class=\"modal-title-strip\">\n          <h3 class=\"modal-title\" id=\"cert-modal-title\">Certifications &amp; Degrees</h3>\n          <p class=\"modal-subtitle\">A single view of formal education and industry credentials.</p>\n        </div>\n        <div class=\"modal-body cert-modal-body\">\n          <div class=\"cert-modal-grid\">\n            <article class=\"cert-card\">\n              <div class=\"cert-card-header\">\n                <img src=\"img/cert_logos/purdue_global-48.png\" srcset=\"img/cert_logos/purdue_global.png 2x\" alt=\"Purdue Global University logo\" class=\"cert-card-logo\" width=\"52\" height=\"52\">\n                <div>\n                  <p class=\"cert-card-label\">Degree</p>\n                  <h4>B.S. – Data Analytics</h4>\n                  <p class=\"cert-card-meta\">Purdue Global University</p>\n                </div>\n              </div>\n              <p class=\"cert-card-note\">Curriculum spanned programming in Python, R, and Java alongside advanced statistics, AI/machine learning coursework, and exposure to big-data stacks such as Hadoop and Spark.</p>\n              <div class=\"cert-card-actions\">\n                <a class=\"btn-secondary\" href=\"https://www.credential.net/0f4df6f1-112e-4e4e-8cb1-b97e7ecd3a3b\" target=\"_blank\" rel=\"noopener noreferrer\">View credential</a>\n              </div>\n            </article>\n            <article class=\"cert-card\">\n              <div class=\"cert-card-header\">\n                <img src=\"img/cert_logos/eastern-48.png\" srcset=\"img/cert_logos/eastern.png 2x\" alt=\"Eastern University logo\" class=\"cert-card-logo\" width=\"52\" height=\"52\">\n                <div>\n                  <p class=\"cert-card-label\">Degree</p>\n                  <h4>M.S. – Data Science</h4>\n                  <p class=\"cert-card-meta\">Eastern University</p>\n                </div>\n              </div>\n              <p class=\"cert-card-note\">Degree covering Python, R, SQL, and statistical modeling with electives in data manipulation, visualization, machine learning, and an applied capstone project.</p>\n              <div class=\"cert-card-actions\">\n                <p class=\"cert-card-note subtle\">No public credential available; verification provided upon request.</p>\n              </div>\n            </article>\n            <article class=\"cert-card\">\n              <div class=\"cert-card-header\">\n                <img src=\"img/cert_logos/ibm-48.png\" srcset=\"img/cert_logos/ibm.png 2x\" alt=\"IBM logo\" class=\"cert-card-logo\" width=\"52\" height=\"52\">\n                <div>\n                  <p class=\"cert-card-label\">Certification</p>\n                  <h4>IBM Data Analyst Professional Certificate</h4>\n                  <p class=\"cert-card-meta\">IBM / Coursera</p>\n                </div>\n              </div>\n              <p class=\"cert-card-note\">Built Excel, SQL, Python, and Cognos workflows inside Jupyter Notebooks, culminating in a capstone that applies the toolkit to a real-world analytics scenario.</p>\n              <div class=\"cert-card-actions\">\n                <a class=\"btn-secondary\" href=\"https://www.coursera.org/account/accomplishments/specialization/certificate/CYUMPN7ZQRDA\" target=\"_blank\" rel=\"noopener noreferrer\">View credential</a>\n              </div>\n            </article>\n            <article class=\"cert-card\">\n              <div class=\"cert-card-header\">\n                <img src=\"img/cert_logos/ibm-48.png\" srcset=\"img/cert_logos/ibm.png 2x\" alt=\"IBM logo\" class=\"cert-card-logo\" width=\"52\" height=\"52\">\n                <div>\n                  <p class=\"cert-card-label\">Certification</p>\n                  <h4>IBM Machine Learning Professional Certificate</h4>\n                  <p class=\"cert-card-meta\">IBM / Coursera</p>\n                </div>\n              </div>\n              <p class=\"cert-card-note\">Covered supervised, unsupervised, deep, and reinforcement learning with dedicated regression, classification, and clustering courses using scikit-learn, TensorFlow, Keras, and a final capstone.</p>\n              <div class=\"cert-card-actions\">\n                <a class=\"btn-secondary\" href=\"https://www.coursera.org/account/accomplishments/specialization/certificate/7262X6HH5NF2\" target=\"_blank\" rel=\"noopener noreferrer\">View credential</a>\n              </div>\n            </article>\n            <article class=\"cert-card\">\n              <div class=\"cert-card-header\">\n                <img src=\"img/cert_logos/google-48.png\" srcset=\"img/cert_logos/google.png 2x\" alt=\"Google logo\" class=\"cert-card-logo\" width=\"52\" height=\"52\">\n                <div>\n                  <p class=\"cert-card-label\">Certification</p>\n                  <h4>Google Data Analytics Professional Certificate</h4>\n                  <p class=\"cert-card-meta\">Google / Coursera</p>\n                </div>\n              </div>\n              <p class=\"cert-card-note\">Completed data cleaning and preparation pipelines, built Tableau dashboards, and delivered an end-to-end R/SQL case study focused on stakeholder-ready storytelling.</p>\n              <div class=\"cert-card-actions\">\n                <a class=\"btn-secondary\" href=\"https://www.coursera.org/account/accomplishments/specialization/certificate/N6MNKYE4MKEP\" target=\"_blank\" rel=\"noopener noreferrer\">View credential</a>\n              </div>\n            </article>\n            <article class=\"cert-card\">\n              <div class=\"cert-card-header\">\n                <img src=\"img/cert_logos/google-48.png\" srcset=\"img/cert_logos/google.png 2x\" alt=\"Google logo\" class=\"cert-card-logo\" width=\"52\" height=\"52\">\n                <div>\n                  <p class=\"cert-card-label\">Certification</p>\n                  <h4>Google Advanced Data Analytics Professional Certificate</h4>\n                  <p class=\"cert-card-meta\">Google / Coursera</p>\n                </div>\n              </div>\n              <p class=\"cert-card-note\">Worked through seven Jupyter Notebook-based courses using Python and Tableau to practice regression, statistics, machine learning, and experimental design before a culminating capstone.</p>\n              <div class=\"cert-card-actions\">\n                <a class=\"btn-secondary\" href=\"https://www.coursera.org/account/accomplishments/specialization/certificate/K47AGB33F8VS\" target=\"_blank\" rel=\"noopener noreferrer\">View credential</a>\n              </div>\n            </article>\n            <article class=\"cert-card\">\n              <div class=\"cert-card-header\">\n                <img src=\"img/cert_logos/google-48.png\" srcset=\"img/cert_logos/google.png 2x\" alt=\"Google logo\" class=\"cert-card-logo\" width=\"52\" height=\"52\">\n                <div>\n                  <p class=\"cert-card-label\">Certification</p>\n                  <h4>Google Analytics Certification</h4>\n                  <p class=\"cert-card-meta\">Google Skillshop</p>\n                </div>\n              </div>\n              <p class=\"cert-card-note\">Validated proficiency in GA4 implementation, conversion tracking, event modeling, and insight generation using the latest Analytics interface.</p>\n              <div class=\"cert-card-actions\">\n                <a class=\"btn-secondary\" href=\"https://skillshop.credential.net/2b2a612a-fbe8-4bbd-b882-0536b2f1d96a\" target=\"_blank\" rel=\"noopener noreferrer\">View credential</a>\n              </div>\n            </article>\n          </div>\n        </div>\n      </div>\n    </div>"
        }
      },
      {
        "id": "audience-analytics-7",
        "type": "legacy-html",
        "label": "Work Experience",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"work-experience\" class=\"surface-band reveal work-band\" role=\"region\" aria-labelledby=\"work-experience-title\">\n      <div class=\"wrapper\">\n        <div class=\"work-head\">\n          <h2 id=\"work-experience-title\" class=\"section-title\">Work Experience</h2>\n          <p class=\"work-subtitle\">Recent roles with measurable impact across reporting, data quality, retail operations, and broader business analysis.</p>\n        </div>\n\n        <div class=\"work-grid\" role=\"list\" aria-label=\"Work experience\">\n          <article class=\"work-card\" role=\"listitem\">\n            <a class=\"work-logo-shell work-logo-link\" href=\"https://www.target.com/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Target website\">\n              <img src=\"img/company_logos/target-256.png\" srcset=\"img/company_logos/target-256.png 1x, img/company_logos/target-512.png 2x\" alt=\"\" width=\"256\" height=\"256\" loading=\"lazy\" decoding=\"async\">\n            </a>\n            <h3 class=\"work-company\">Target</h3>\n            <p class=\"work-timeframe\">June 2022 – November 2023</p>\n            <p class=\"work-role\">Asset Protection Data Analyst</p>\n            <ul class=\"work-highlights\">\n              <li>Designed dashboards that boosted theft reporting by 57.6% and increased prevention 180%.</li>\n              <li>Reduced inventory loss by 24% through analytics-driven investigations and tooling.</li>\n              <li>Presented actionable insights to non-technical stakeholders across multiple teams.</li>\n            </ul>\n          </article>\n\n          <article class=\"work-card\" role=\"listitem\">\n            <a class=\"work-logo-shell work-logo-link\" href=\"https://www.randallreilly.com/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Randall Reilly website\">\n              <img src=\"img/company_logos/randall-reilly.png\" alt=\"\" width=\"200\" height=\"200\" loading=\"lazy\" decoding=\"async\">\n            </a>\n            <h3 class=\"work-company\">Randall Reilly</h3>\n            <p class=\"work-timeframe\">November 2023 – January 2024</p>\n            <p class=\"work-role\">AI Data Quality Analyst</p>\n            <ul class=\"work-highlights\">\n              <li>Re-platformed R workflows into a one-click Python app, cutting delivery time by 95%.</li>\n              <li>Expanded serial tracking by 10x with decision trees and delivered 98% anomaly precision.</li>\n              <li>Deployed an autoencoder model that lifted overall data quality for downstream analytics.</li>\n            </ul>\n          </article>\n\n          <article class=\"work-card\" role=\"listitem\">\n            <a class=\"work-logo-shell work-logo-link\" href=\"https://www.visitgrandjunction.com/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Visit Grand Junction website\">\n              <img src=\"img/company_logos/visit-grand-junction.png\" alt=\"\" width=\"284\" height=\"225\" loading=\"lazy\" decoding=\"async\">\n            </a>\n            <h3 class=\"work-company\">Visit Grand Junction</h3>\n            <p class=\"work-timeframe\">February 2024 – Present</p>\n            <p class=\"work-role\">Business Analyst</p>\n            <ul class=\"work-highlights\">\n              <li>Automated Industry Data Reports and stakeholder reporting, saving 200+ hours annually and cutting turnaround 99%.</li>\n              <li>Authored semimonthly council and stakeholder updates using tourism, lodging, and web-performance data.</li>\n              <li>Identified lodging cannibalization by reconciling tax records with occupancy, ADR, and RevPAR, shaping council updates and strategy.</li>\n              <li>Researched traveler trends and AI search behavior to guide content and GEO strategy, contributing to +9.4% organic sessions and 10x AI referrals YoY.</li>\n            </ul>\n          </article>\n        </div>\n      </div>\n    </section>"
        }
      },
      {
        "id": "audience-analytics-8",
        "type": "legacy-html",
        "label": "Skills in Practice",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"about-me\" class=\"surface-band reveal interest-pad\">\n      <div class=\"wrapper\">\n        <h2 class=\"section-title\">Skills in Practice</h2>\n        <p class=\"skill-subtitle\">Examples of how the technical toolkit shows up in real projects, from SQL workflows and dashboard design to Python modeling and statistical analysis.</p>\n\n        <div class=\"grid-container\">\n          <a class=\"icon-info grid-item skill-link\" href=\"portfolio/nonogram\" aria-label=\"View Nonogram Solver case study\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n              <path d=\"M8 17l-5-5 5-5\"/>\n              <path d=\"M16 7l5 5-5 5\"/>\n              <path d=\"M13 5l-2 14\"/>\n            </svg>\n            <p>Programming<small class=\"skill-link-btn\">(Python)</small></p>\n            <small class=\"skill-link-btn\">Trained a reinforcement learning agent to solve 5×5 puzzles.</small>\n          </a>\n\n          <a class=\"icon-info grid-item skill-link\" href=\"portfolio/pizzaDashboard\" aria-label=\"View Pizza Delivery Dashboard case study\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n              <path d=\"M3 3v18h18\"/>\n              <path d=\"M7 15l4-4 3 3 5-7\"/>\n            </svg>\n            <p>Data Visualization<small class=\"skill-link-btn\">(Tableau)</small></p>\n            <small class=\"skill-link-btn\">Cut delivery decision time from 5 min to 1 min with a live KPI dashboard.</small>\n          </a>\n\n          <a class=\"icon-info grid-item skill-link\" href=\"portfolio/retailStore\" aria-label=\"View Store-Level Loss &amp; Sales ETL case study\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n              <ellipse cx=\"12\" cy=\"5\" rx=\"8\" ry=\"3\"/>\n              <path d=\"M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5\"/>\n              <path d=\"M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6\"/>\n            </svg>\n            <p>SQL &amp; ETL<small class=\"skill-link-btn\">(MSSQL, Python)</small></p>\n            <small class=\"skill-link-btn\">Flagged outlier stores and regions using anomaly detection (anonymized).</small>\n          </a>\n\n          <a class=\"icon-info grid-item skill-link\" href=\"portfolio/covidAnalysis\" aria-label=\"View COVID-19 outbreak analysis case study\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n              <path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/>\n              <path d=\"M14 2v6h6\"/>\n              <path d=\"M8 13h8\"/>\n              <path d=\"M8 17h5\"/>\n            </svg>\n            <p>Data Wrangling<small class=\"skill-link-btn\">(Pandas)</small></p>\n            <small class=\"skill-link-btn\">Built an early-warning ICU risk model and explained drivers with SHAP.</small>\n          </a>\n\n          <a class=\"icon-info grid-item skill-link\" href=\"portfolio/handwritingRating\" aria-label=\"View Handwriting Rating case study\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n              <circle cx=\"12\" cy=\"12\" r=\"3\"/>\n              <path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.1a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.1a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.1a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9c0 .66.26 1.3.73 1.77.47.47 1.11.73 1.77.73h.1a2 2 0 1 1 0 4h-.1a1.65 1.65 0 0 0-1.51 1z\"/>\n            </svg>\n            <p>Machine Learning<small class=\"skill-link-btn\">(PyTorch)</small></p>\n            <small class=\"skill-link-btn\">Deployed a CNN that reads digits with ~99% accuracy and scored my handwriting on a personal sample.</small>\n          </a>\n\n          <a class=\"icon-info grid-item skill-link\" href=\"portfolio/pizza\" aria-label=\"View Pizza Tip Analysis case study\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n              <path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/>\n              <path d=\"M14 2v6h6\"/>\n              <path d=\"M8 13l8 0\"/>\n              <path d=\"M10 17l-2 0\"/>\n            </svg>\n            <p>Regression Analysis<small class=\"skill-link-btn\">(Excel)</small></p>\n            <small class=\"skill-link-btn\">Found apartment deliveries tended to tip less; order cost was the strongest predictor.</small>\n          </a>\n        </div>\n      </div>\n    </section>"
        }
