{
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/demos/**/*.js": { "maxDuration": 150 },
    "api/sentence-demo/**/*.js": { "maxDuration": 150 },
    "api/chatbot.js": { "maxDuration": 60 },
    "api/chatbot-stream.js": { "maxDuration": 60 },
    "api/tools/**/*.js": { "maxDuration": 60 }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "env": {
    "CHATBOT_ENABLED": "true",
    "CHATBOT_REQUIRE_DDB": "true",
    "CHATBOT_BEDROCK_MODEL_ID": "us.amazon.nova-lite-v1:0",
    "CHATBOT_EMBEDDINGS_ENABLED": "true",
    "CHATBOT_EMBEDDINGS_REQUIRED": "false",
    "CHATBOT_BEDROCK_EMBED_MODEL_ID": "amazon.titan-embed-text-v2:0",
    "CHATBOT_BEDROCK_EMBED_DIMENSIONS": "512"
  },
