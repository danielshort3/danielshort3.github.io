---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Daniel Short" description="About Daniel Short, data scientist focused on measurable business outcomes.">
  <main id="main" class="mx-auto max-w-4xl px-4 pb-20 pt-10 sm:px-6">
    <a href="/" class="text-sm text-cyan-200 hover:text-cyan-100">← Back to portfolio grid</a>

    <section class="surface-card mt-5">
      <h1 class="text-3xl font-bold text-cyan-50">About Daniel Short</h1>
      <p class="mt-4 text-cyan-100/90">
        Data Scientist specializing in NLP, computer vision, and ETL systems with a record of measurable delivery: up
        to 500% KPI gains, 200+ hours/year saved through automation, and 750% traffic lift on production initiatives.
      </p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <article class="rounded-xl border border-cyan-300/25 bg-slate-950/60 p-4">
          <h2 class="font-semibold text-cyan-50">Visit Grand Junction</h2>
          <p class="mt-2 text-sm text-cyan-100/85">
            Built analytics-informed campaign and content systems to increase qualified traffic and reporting clarity.
          </p>
        </article>

        <article class="rounded-xl border border-cyan-300/25 bg-slate-950/60 p-4">
          <h2 class="font-semibold text-cyan-50">Target</h2>
          <p class="mt-2 text-sm text-cyan-100/85">
            Delivered operations-focused ETL automation and anomaly detection workflows tied to shrink and margin
            outcomes.
          </p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
