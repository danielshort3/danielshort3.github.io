      {
        "id": "home-about",
        "type": "legacy-html",
        "label": "About",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"about\" class=\"surface-band reveal destination-section\" aria-labelledby=\"about-title\"><div class=\"wrapper\"><div class=\"destination-section-head\"><h2 id=\"about-title\">About</h2><p>I like projects that make messy information easier to inspect, explain, and use. Most of what I publish here sits somewhere between data analysis, software tooling, machine learning, and practical web interfaces.</p></div><div id=\"cta-link\" role=\"group\" aria-label=\"Contact call to action\"><h2 class=\"section-title\">Say hello</h2><p>Send a note about a project, a tool, an idea, or something on the site.</p><div><a href=\"contact\" class=\"btn-primary\">Contact</a></div></div></div></section>"
