---
import "../styles/global.css";

const projects = [
  {
    title: "Retail Loss ETL",
    impact: "24% reduction in loss",
    summary:
      "Automated cross-system ETL and risk surfacing to replace delayed, manual shrink reporting."
  },
  {
    title: "Edge AI Handwriting Recognition",
    impact: "Sub-10ms target latency",
    summary:
      "Client-side ONNX inference architecture for low-latency recognition without backend dependency."
  },
  {
    title: "Computer Vision Document Restoration",
    impact: "Generative cleanup pipeline",
    summary:
      "Generative CV workflow for watermark removal and notation restoration from damaged scans."
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Projects | Daniel Short</title>
    <meta
      name="description"
      content="Portfolio projects focused on ETL, edge AI, and computer vision with strong business impact."
    />
  </head>
  <body class="font-sans text-deep-text antialiased">
    <main class="mx-auto min-h-screen w-full max-w-6xl px-4 py-10">
      <a href="/" class="mb-8 inline-block text-sm text-cyan-300 transition hover:text-cyan-200">
        ← Back to home
      </a>
      <h1 class="text-3xl font-bold text-slate-100 md:text-4xl">Projects</h1>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {
          projects.map((project) => (
            <article class="bento-card">
              <p class="text-xs uppercase tracking-[0.14em] text-cyan-300/85">{project.impact}</p>
              <h2 class="mt-2 text-xl font-semibold text-slate-50">{project.title}</h2>
              <p class="mt-3 text-sm leading-6 text-deep-muted">{project.summary}</p>
            </article>
          ))
        }
      </div>
    </main>
  </body>
</html>
