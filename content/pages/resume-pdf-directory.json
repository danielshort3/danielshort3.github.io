        "html": "<section class=\"surface-band resume-section\">\n      <div class=\"wrapper\">\n        <div class=\"resume-paper\" role=\"document\" aria-label=\"Daniel Short PDF resume versions\">\n          <header class=\"resume-paper-header\">\n            <p class=\"resume-eyebrow\">Resume PDF versions</p>\n            <h1 class=\"resume-name\">Choose the PDF that matches the role.</h1>\n            <p class=\"resume-summary\">Analytics is the default PDF resume. The data science and tourism PDFs are available here when you need a different version.</p>\n          </header>\n\n          <section class=\"resume-projects-wide\" aria-label=\"PDF resume options\">\n            <h2 class=\"resume-block-title resume-wide-category\"><span>Available PDF versions</span></h2>\n            <ul class=\"resume-projects-grid\">\n              <li class=\"resume-project\">\n                <a class=\"resume-project-title\" href=\"resume-analytics-pdf\">Analytics Resume PDF</a>\n                <p class=\"resume-project-meta\">Preview or download the BI and reporting version.</p>\n              </li>\n              <li class=\"resume-project\">\n                <a class=\"resume-project-title\" href=\"resume-data-science-pdf\">Data Science Resume PDF</a>\n                <p class=\"resume-project-meta\">Preview or download the machine learning version.</p>\n              </li>\n              <li class=\"resume-project\">\n                <a class=\"resume-project-title\" href=\"resume-tourism-pdf\">Tourism Resume PDF</a>\n                <p class=\"resume-project-meta\">Preview or download the destination analytics version.</p>\n              </li>\n            </ul>\n          </section>\n        </div>\n      </div>\n    </section>"
