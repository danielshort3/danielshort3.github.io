    "sections": [
      {
        "id": "home-hero",
        "type": "legacy-html",
        "label": "Daniel Short",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section class=\"hero hero--default\"><div class=\"wrapper\"><h1>Daniel Short</h1><div class=\"hero-identity\"><img class=\"hero-avatar\" src=\"img/hero/head-avatar-192.jpg\" srcset=\"img/hero/head-avatar-192.jpg 192w, img/hero/head-avatar-384.jpg 384w\" sizes=\"(max-width: 768px) 112px, 132px\" alt=\"Portrait of Daniel Short\" width=\"132\" height=\"132\" decoding=\"async\" fetchpriority=\"high\"><p class=\"hero-eyebrow\">Projects, tools, and applied data work</p></div><p class=\"hero-tagline\">This is my personal site for things I build, study, and keep refining: data projects, web tools, small games, writing utilities, and practical builds.</p><div class=\"cta-group\"><a href=\"portfolio\" class=\"btn-primary hero-cta\">Projects</a><a href=\"tools\" class=\"btn-secondary hero-cta\">Tools</a><a href=\"games\" class=\"btn-secondary hero-cta\">Games</a></div></div><a class=\"chevron-hint scroll-indicator\" href=\"#featured-projects\" data-smooth-scroll=\"true\"><span class=\"chevron-label\">View featured work</span><svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M12 16.5a1 1 0 0 1-.7-.29l-6-6a1 1 0 1 1 1.4-1.42L12 14.08l5.3-5.29a1 1 0 0 1 1.4 1.42l-6 6a1 1 0 0 1-.7.29z\"/></svg></a></section>"
        }
      },
      {
        "id": "home-featured-projects",
        "type": "legacy-html",
        "label": "Projects",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"featured-projects\" class=\"project-examples-band surface-band no-reveal\" role=\"region\" aria-labelledby=\"featured-projects-title\"><div class=\"wrapper\"><div class=\"project-examples-head\"><h2 id=\"featured-projects-title\">Projects</h2><p class=\"project-examples-subtitle\">A few representative projects across analytics, language models, and image generation.</p></div><div class=\"home-showcase-grid\" role=\"list\" aria-label=\"Featured projects\"><article class=\"home-showcase-card\" role=\"listitem\"><h3>Store-Level Loss &amp; Sales ETL</h3><p class=\"home-showcase-summary\">SQL pipeline and anomaly views for comparing loss signals against store sales context.</p><a class=\"btn-secondary\" href=\"portfolio/retailStore\">View project</a></article><article class=\"home-showcase-card\" role=\"listitem\"><h3>RAG Chatbot Fine-Tuned with LoRA</h3><p class=\"home-showcase-summary\">Source-grounded chatbot demo comparing managed RAG responses with a custom fine-tuned path.</p><a class=\"btn-secondary\" href=\"portfolio/chatbotLora\">View project</a></article><article class=\"home-showcase-card\" role=\"listitem\"><h3>Digit Generator</h3><p class=\"home-showcase-summary\">VAE demo that samples a learned digit space to generate new handwritten-style digits.</p><a class=\"btn-secondary\" href=\"portfolio/digitGenerator\">View project</a></article></div><div class=\"project-examples-actions\"><a href=\"portfolio\" class=\"btn-secondary project-examples-cta\">Browse all projects</a></div></div></section>"
        }
      },
      {
        "id": "home-tools",
        "type": "legacy-html",
        "label": "Tools",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"tools-preview\" class=\"surface-band reveal destination-section\" aria-labelledby=\"tools-preview-title\"><div class=\"wrapper\"><div class=\"destination-section-head\"><h2 id=\"tools-preview-title\">Tools</h2><p>Small utilities built for repeated, practical use: writing cleanup, media processing, link building, and quick analysis.</p></div><div class=\"home-showcase-grid\" role=\"list\" aria-label=\"Featured tools\"><article class=\"home-showcase-card\" role=\"listitem\"><h3>Text Compare</h3><p class=\"home-showcase-summary\">Compare two drafts and highlight insertions, deletions, and replacements inline.</p><a class=\"btn-secondary\" href=\"tools/text-compare\">Open text compare</a></article><article class=\"home-showcase-card\" role=\"listitem\"><h3>Word Count</h3><p class=\"home-showcase-summary\">Paste text, remove stopwords, and review frequent words locally in the browser.</p><a class=\"btn-secondary\" href=\"tools/word-frequency\">Open word count</a></article><article class=\"home-showcase-card\" role=\"listitem\"><h3>QR Code Generator</h3><p class=\"home-showcase-summary\">Create branded QR codes with templates, logo embedding, and high-resolution exports.</p><a class=\"btn-secondary\" href=\"tools/qr-code-generator\">Open QR generator</a></article></div><div class=\"home-showcase-actions\"><a href=\"tools\" class=\"btn-secondary\">View all tools</a></div></div></section>"
        }
      },
      {
        "id": "home-games",
        "type": "legacy-html",
        "label": "Games",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"games-preview\" class=\"surface-band reveal destination-section\" aria-labelledby=\"games-preview-title\"><div class=\"wrapper\"><div class=\"destination-section-head\"><h2 id=\"games-preview-title\">Games</h2><p>Small browser games and simulations built around interaction, state, feedback, and probability.</p></div><div class=\"home-showcase-grid\" role=\"list\" aria-label=\"Featured games\"><article class=\"home-showcase-card\" role=\"listitem\"><h3>Stellar Dogfight</h3><p class=\"home-showcase-summary\">Pilot a fighter, duel adaptive AI opponents, and stack upgrades between waves.</p><a class=\"btn-secondary\" href=\"games/stellar-dogfight\">Play dogfight</a></article><article class=\"home-showcase-card\" role=\"listitem\"><h3>Double-Zero Roulette</h3><p class=\"home-showcase-summary\">Play an American roulette table and track hot pockets across recent spins.</p><a class=\"btn-secondary\" href=\"games/roulette\">Play roulette</a></article><article class=\"home-showcase-card\" role=\"listitem\"><h3>Probability Engine</h3><p class=\"home-showcase-summary\">Build slot reels, chain synergies, and tune long-run probability systems.</p><a class=\"btn-secondary\" href=\"games/probability-engine\">Open engine</a></article></div><div class=\"home-showcase-actions\"><a href=\"games\" class=\"btn-secondary\">View all games</a></div></div></section>"
        }
      },
      {
        "id": "home-contact",
        "type": "legacy-html",
        "label": "Contact",
        "enabled": true,
        "variant": "default",
        "props": {
          "html": "<section id=\"contact-preview\" class=\"surface-band reveal destination-section\" aria-labelledby=\"contact-preview-title\"><div class=\"wrapper\"><div id=\"cta-link\" class=\"home-contact-panel\" role=\"group\" aria-label=\"Contact call to action\"><div class=\"home-contact-copy\"><h2 id=\"contact-preview-title\" class=\"section-title\">Say hello</h2><p>Send a note about a project, a tool, an idea, or something on the site.</p></div><div class=\"home-contact-actions\" aria-label=\"Contact options\"><a href=\"contact#contact-modal\" class=\"btn-primary\" data-contact-modal-link=\"true\">Contact form</a><a href=\"mailto:daniel@danielshort.me\" class=\"btn-secondary\">Email</a></div></div></div></section>"
        }
