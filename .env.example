# Short links admin (set a long random value)
SHORTLINKS_ADMIN_TOKEN=

# Short links storage (AWS DynamoDB)
SHORTLINKS_DDB_TABLE=
# Required for synchronized click totals and durable history (partition key: slug, sort key: clickId)
SHORTLINKS_DDB_CLICKS_TABLE=
AWS_REGION=

# Shared AWS auth mode. Use oidc on Vercel after the environment-specific role
# ARNs below are configured; auto retains local/static credential compatibility.
AWS_AUTH_MODE=auto
AWS_OIDC_AUDIENCE=sts.amazonaws.com

# -------------------------------------------------------------------
# IAM-private AWS portfolio demos
# -------------------------------------------------------------------

DEMO_PROXY_MODE=oidc
DEMO_AWS_REGION=us-east-2
DEMO_INVOKE_AWS_ROLE_ARN=
DEMO_RATE_LIMIT_TABLE=
DEMO_HASH_SALT=
DEMO_REQUIRE_DDB_RATE_LIMIT=true
DEMO_SHAPE_FUNCTION_ARN=
DEMO_DIGIT_GENERATOR_FUNCTION_ARN=
DEMO_HANDWRITING_FUNCTION_ARN=
DEMO_MINESWEEPER_FUNCTION_ARN=
DEMO_NONOGRAM_FUNCTION_ARN=
DEMO_PIZZA_TIPS_FUNCTION_ARN=
DEMO_SMART_SENTENCE_FUNCTION_ARN=
DEMO_COVID_OUTBREAK_FUNCTION_ARN=
DEMO_TARGET_EMPTY_PACKAGE_FUNCTION_ARN=
DEMO_RETAIL_LOSS_SALES_FUNCTION_ARN=
# Optional local/recovery fallback only. Vercel should use the OIDC role above.
DEMO_AWS_ACCESS_KEY_ID=
DEMO_AWS_SECRET_ACCESS_KEY=
DEMO_AWS_SESSION_TOKEN=

# Preferred Vercel OIDC role. Static keys remain a temporary fallback.
SHORTLINKS_AWS_ROLE_ARN=
# Prefer these to avoid conflicts with other AWS integrations/env vars.
SHORTLINKS_AWS_ACCESS_KEY_ID=
SHORTLINKS_AWS_SECRET_ACCESS_KEY=
# Only for temporary creds (usually access keys starting with ASIA)
SHORTLINKS_AWS_SESSION_TOKEN=

# Fallback (standard AWS SDK env vars)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Contact form proxy (same-origin /api/contact -> upstream form handler)
CONTACT_FORM_UPSTREAM=

# Google Maps Embed API for build-time public map iframe URLs.
# Local builds also fall back to google_maps_api_key.txt, which must not be committed.
GOOGLE_MAPS_API_KEY=

# -------------------------------------------------------------------
# Embedded site chatbot (AWS Bedrock + generated site knowledge)
# -------------------------------------------------------------------

# Set false only when intentionally hiding the embedded website chatbot.
CHATBOT_ENABLED=true

# Bedrock model/region. Nova Lite uses the us.* inference profile.
CHATBOT_BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
# Optional second Bedrock call that writes post-answer follow-up chips. Uses CHATBOT_BEDROCK_MODEL_ID when blank.
CHATBOT_MODEL_FOLLOWUPS_ENABLED=true
CHATBOT_BEDROCK_FOLLOWUP_MODEL_ID=
CHATBOT_AWS_REGION=us-east-2
CHATBOT_BEDROCK_AWS_ROLE_ARN=
CHATBOT_DDB_AWS_ROLE_ARN=
# Qualified Lambda alias ARN used by /api/chatbot-stream. Production requires :live.
CHATBOT_STREAM_FUNCTION_ARN=
# Optional dedicated role; otherwise the proxy reuses DEMO_INVOKE_AWS_ROLE_ARN.
CHATBOT_STREAM_AWS_ROLE_ARN=
CHATBOT_AWS_ACCESS_KEY_ID=
CHATBOT_AWS_SECRET_ACCESS_KEY=
CHATBOT_AWS_SESSION_TOKEN=

# Optional build-time Bedrock embeddings for hybrid retrieval. Falls back to lexical search when unavailable.
CHATBOT_EMBEDDINGS_ENABLED=true
CHATBOT_EMBEDDINGS_REQUIRED=false
CHATBOT_BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
CHATBOT_BEDROCK_EMBED_DIMENSIONS=512

# DynamoDB table for rate limits and chatbot logs. Use partition key "pk", sort key "sk", optional TTL attr "ttl".
CHATBOT_DDB_TABLE=
CHATBOT_HASH_SALT=
# Set true to fail closed unless CHATBOT_DDB_TABLE and CHATBOT_HASH_SALT are configured.
CHATBOT_REQUIRE_DDB=false
# Log retention and token-protected investigation API (/api/chatbot/logs).
CHATBOT_LOG_TTL_DAYS=30
CHATBOT_ADMIN_TOKEN=

# Abuse controls.
CHATBOT_MIN_SECONDS_BETWEEN_QUERIES=8
CHATBOT_WINDOW_SECONDS=600
CHATBOT_WINDOW_LIMIT=8
CHATBOT_DAILY_LIMIT=40
CHATBOT_GLOBAL_DAILY_LIMIT=250
CHATBOT_RATE_LIMIT_TTL_DAYS=3
CHATBOT_MAX_MESSAGE_CHARS=1000
CHATBOT_MAX_OUTPUT_TOKENS=420

# Cloudflare Turnstile.
CHATBOT_TURNSTILE_SITE_KEY=
CHATBOT_TURNSTILE_SECRET_KEY=

# Optional comma-separated origin allowlist beyond production, localhost, and current Vercel preview.
CHATBOT_ALLOWED_ORIGINS=

# -------------------------------------------------------------------
# Tools accounts (shared auth + saved sessions/activity)
# -------------------------------------------------------------------

# Cognito (server-side JWT verification)
# Example issuer: https://cognito-idp.us-east-2.amazonaws.com/us-east-2_XXXXXXXXX
TOOLS_COGNITO_ISSUER=
# Cognito app client id (matches the "aud" claim on ID tokens)
TOOLS_COGNITO_CLIENT_ID=

# AES-256-GCM authenticated, same-origin __Host HttpOnly tools session
# (Secure; SameSite=Lax; Path=/). Generate a 32-byte base64url
# key with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Rotation: put the new key first and retain the previous key after a comma
# until every cookie issued with it has expired. Never commit either value.
TOOLS_SESSION_SECRETS=
# Cookie lifetime is clamped to 15 minutes through 24 hours (default: 8 hours).
TOOLS_SESSION_TTL_SECONDS=28800
# Bearer fallback defaults to true when omitted. Keep true during dual rollout.
# Set false only after cookie-mode API
# and Job Tracker proxy canaries pass in both Preview and Production.
TOOLS_AUTH_BEARER_FALLBACK=true

# Storage backend (AWS DynamoDB)
TOOLS_DDB_TABLE=
TOOLS_AWS_ROLE_ARN=
# Enable DynamoDB TTL on this attribute. Retention is refreshed whenever a session is saved.
TOOLS_DDB_TTL_ATTRIBUTE=ttl
TOOLS_SESSION_RETENTION_DAYS=365
TOOLS_ACTIVITY_RETENTION_DAYS=90
# Per-account safety ceilings for saved sessions.
TOOLS_MAX_SESSIONS_PER_TOOL=50
TOOLS_MAX_SESSIONS_PER_USER=250
# Guardrail for the authenticated delete-all operation.
TOOLS_DELETE_ALL_MAX_ITEMS=10000
TOOLS_DELETE_LOCK_SECONDS=900

# Prefer these to avoid conflicts with other AWS integrations/env vars
TOOLS_AWS_ACCESS_KEY_ID=
TOOLS_AWS_SECRET_ACCESS_KEY=
# Only for temporary creds (usually access keys starting with ASIA)
TOOLS_AWS_SESSION_TOKEN=

# Optional local-only compatibility fallback (no quotas, TTL, versions, or delete-all).
# Production always fails closed unless DynamoDB is configured.
TOOLS_ALLOW_KV_COMPAT=false
# Vercel KV:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Upstash:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# -------------------------------------------------------------------
# File transcription tool (Amazon Transcribe + private S3 uploads)
# -------------------------------------------------------------------

TRANSCRIBE_AWS_REGION=us-east-2
TRANSCRIBE_AWS_ROLE_ARN=
TRANSCRIBE_UPLOAD_BUCKET=
TRANSCRIBE_UPLOAD_PREFIX=tools-transcribe/
TRANSCRIBE_SIGNING_SECRET=
TRANSCRIBE_PRICE_PER_SECOND=0.0004
TRANSCRIBE_MAX_FILES_PER_RUN=10
TRANSCRIBE_MAX_FILE_BYTES=524288000
TRANSCRIBE_MAX_TOTAL_COST_USD=10
TRANSCRIBE_LANGUAGE_CODE=en-US
TRANSCRIBE_RUN_TOKEN_TTL_SECONDS=86400

# Durable per-user spend/file/concurrency ledger. Defaults to required. The
# dedicated table may be omitted when TOOLS_DDB_TABLE is already configured.
TRANSCRIBE_DDB_TABLE=
TRANSCRIBE_DDB_TTL_ATTRIBUTE=ttl
TRANSCRIBE_LEDGER_MODE=required
# Each accepted job pessimistically reserves the AWS 8-hour maximum cost ($11.52 at the default rate).
TRANSCRIBE_DAILY_COST_LIMIT_USD=25
TRANSCRIBE_DAILY_FILE_LIMIT=50
TRANSCRIBE_GLOBAL_DAILY_COST_LIMIT_USD=100
TRANSCRIBE_GLOBAL_DAILY_FILE_LIMIT=200
TRANSCRIBE_MAX_CONCURRENT=2
TRANSCRIBE_LEDGER_START_LEASE_SECONDS=300
TRANSCRIBE_LEDGER_LEASE_SECONDS=43200
TRANSCRIBE_LEDGER_RENEWAL_SECONDS=60
TRANSCRIBE_LEDGER_RUN_RETENTION_DAYS=45
TRANSCRIBE_LEDGER_DAY_RETENTION_DAYS=45

# Bounds for downloading the completed transcript JSON from AWS.
TRANSCRIBE_TRANSCRIPT_FETCH_TIMEOUT_MS=12000
TRANSCRIBE_MAX_TRANSCRIPT_FETCH_BYTES=26214400
# Keep the final JSON response safely below Vercel's response payload ceiling.
TRANSCRIBE_MAX_TRANSCRIPT_BYTES=3145728

# Optional local/recovery fallback. Vercel should use TRANSCRIBE_AWS_ROLE_ARN.
TRANSCRIBE_AWS_ACCESS_KEY_ID=
TRANSCRIBE_AWS_SECRET_ACCESS_KEY=
# Only for temporary creds (usually access keys starting with ASIA)
TRANSCRIBE_AWS_SESSION_TOKEN=

# -------------------------------------------------------------------
# GA4 Data API (GA4 UTM Performance tool)
# -------------------------------------------------------------------

# Required: a long random value used to gate /api/ga4/report
GA4_ADMIN_TOKEN=

# Required: base64-encoded Google service account JSON key.
# The service account email must be granted at least "Viewer" access on the GA4 property.
GA4_SERVICE_ACCOUNT_JSON_B64=

# Optional: default property ID for the tool (numeric).
GA4_PROPERTY_ID=

# Comma-separated numeric property IDs the API may query. GA4_PROPERTY_ID is always included.
GA4_ALLOWED_PROPERTY_IDS=

# Bounded API behavior (optional overrides).
GA4_MAX_DATE_RANGE_DAYS=366
GA4_MAX_UTM_ROWS=10000
GA4_MAX_EXPLORE_ROWS=5000
GA4_MAX_INSIGHTS_ROWS=5000
GA4_MAX_RESPONSE_BYTES=3145728
GA4_REQUEST_TIMEOUT_MS=10000
GA4_TOTAL_TIMEOUT_MS=25000
GA4_RETRY_ATTEMPTS=3
GA4_RATE_LIMIT_PER_MINUTE=30
GA4_CACHE_TTL_SECONDS=60
GA4_CACHE_MAX_ENTRIES=24
GA4_CACHE_MAX_BYTES=2097152
GA4_CACHE_TOTAL_BYTES=8388608

# Optional alternative to GA4_SERVICE_ACCOUNT_JSON_B64 (not recommended).
GA4_SERVICE_ACCOUNT_JSON=
