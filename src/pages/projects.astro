---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects | Daniel Short" description="Impact-focused data science projects by Daniel Short.">
  <main id="main" class="mx-auto max-w-6xl px-4 pb-20 pt-10 sm:px-6">
    <a href="/" class="text-sm text-cyan-200 hover:text-cyan-100">← Back to portfolio grid</a>

    <section class="mt-5 grid gap-5 md:grid-cols-2">
      <article class="surface-card">
        <div class="mb-3 flex items-center justify-between gap-2">
          <h1 class="text-xl font-semibold text-cyan-50">Retail Loss ETL</h1>
          <span class="metric-badge text-cyan-100">24% reduction in loss</span>
        </div>
        <p class="text-sm text-cyan-100/85">
          Designed and shipped ETL flows that consolidated loss signals into near-real-time operational actions,
          reducing avoidable shrink and improving intervention speed.
        </p>
      </article>

      <article class="surface-card">
        <div class="mb-3 flex items-center justify-between gap-2">
          <h1 class="text-xl font-semibold text-cyan-50">Edge AI Handwriting Recognition</h1>
          <span class="metric-badge text-cyan-100">Sub-10ms latency target</span>
        </div>
        <p class="text-sm text-cyan-100/85">
          Converted a legacy shape-classification demo into a client-side inference experience with ONNX Runtime Web,
          minimizing cold starts and preserving privacy through local execution.
        </p>
      </article>

      <article class="surface-card md:col-span-2">
        <div class="mb-3 flex items-center justify-between gap-2">
          <h1 class="text-xl font-semibold text-cyan-50">Computer Vision Document Restoration</h1>
          <span class="metric-badge text-cyan-100">Generative reconstruction</span>
        </div>
        <p class="text-sm text-cyan-100/85">
          Repositioned sheet music cleanup as a generative restoration task to recover readable notation from noisy,
          watermarked scans while preserving structure for downstream OCR.
        </p>
      </article>
    </section>
  </main>
</BaseLayout>
